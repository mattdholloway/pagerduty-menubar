#!/usr/bin/env bash
# bin/make-icons — regenerate Assets.xcassets/AppIcon.appiconset from docs/logo.svg
# Uses qlmanage (built-in to macOS) plus sips for sizing. No external deps.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

SVG="docs/logo.svg"
OUT="pagerduty-menubar/Assets.xcassets/AppIcon.appiconset"

if [[ ! -f "$SVG" ]]; then
  echo "error: $SVG not found" >&2
  exit 2
fi

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

# Render a large master PNG once, then sips-downsize to each required slot.
qlmanage -t -s 1024 -o "$TMP" "$SVG" >/dev/null 2>&1
MASTER="$TMP/$(basename "$SVG").png"
if [[ ! -f "$MASTER" ]]; then
  echo "error: qlmanage produced no PNG (looked for $MASTER)" >&2
  exit 1
fi

mkdir -p "$OUT"

# macOS AppIcon slots (size, scale, filename).
declare -a slots=(
  "16 1 icon_16x16.png"
  "16 2 icon_16x16@2x.png"
  "32 1 icon_32x32.png"
  "32 2 icon_32x32@2x.png"
  "128 1 icon_128x128.png"
  "128 2 icon_128x128@2x.png"
  "256 1 icon_256x256.png"
  "256 2 icon_256x256@2x.png"
  "512 1 icon_512x512.png"
  "512 2 icon_512x512@2x.png"
)

for s in "${slots[@]}"; do
  read -r size scale file <<<"$s"
  px=$(( size * scale ))
  sips -z "$px" "$px" "$MASTER" --out "$OUT/$file" >/dev/null
done

# Write the Contents.json manifest.
cat >"$OUT/Contents.json" <<'JSON'
{
  "images" : [
    { "size" : "16x16",   "idiom" : "mac", "filename" : "icon_16x16.png",     "scale" : "1x" },
    { "size" : "16x16",   "idiom" : "mac", "filename" : "icon_16x16@2x.png",  "scale" : "2x" },
    { "size" : "32x32",   "idiom" : "mac", "filename" : "icon_32x32.png",     "scale" : "1x" },
    { "size" : "32x32",   "idiom" : "mac", "filename" : "icon_32x32@2x.png",  "scale" : "2x" },
    { "size" : "128x128", "idiom" : "mac", "filename" : "icon_128x128.png",   "scale" : "1x" },
    { "size" : "128x128", "idiom" : "mac", "filename" : "icon_128x128@2x.png","scale" : "2x" },
    { "size" : "256x256", "idiom" : "mac", "filename" : "icon_256x256.png",   "scale" : "1x" },
    { "size" : "256x256", "idiom" : "mac", "filename" : "icon_256x256@2x.png","scale" : "2x" },
    { "size" : "512x512", "idiom" : "mac", "filename" : "icon_512x512.png",   "scale" : "1x" },
    { "size" : "512x512", "idiom" : "mac", "filename" : "icon_512x512@2x.png","scale" : "2x" }
  ],
  "info" : { "version" : 1, "author" : "xcode" }
}
JSON

echo "Wrote AppIcon to $OUT"
ls -l "$OUT"
